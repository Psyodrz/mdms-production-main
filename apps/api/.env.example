# ─────────────────────────────────────────────────────────────
# MDMS API — environment template. Copy to .env.local (dev) or set
# these in your host's secret manager (production). Never commit real values.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
API_PORT=4000
# Public URL of the web app (used for CORS allow-list)
APP_URL=http://localhost:3000

# Postgres connection string (Supabase → Project Settings → Database → Connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis connection string (managed Redis or local docker)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=generate-64-char-random-hex
JWT_REFRESH_SECRET=generate-64-char-random-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Generic auth secret (also 64-char random hex)
AUTH_SECRET=generate-64-char-random-hex

# Supabase JWT secret — Supabase Dashboard → Project Settings → API → JWT Secret
# (used to validate Supabase user access tokens on the API)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard
# Supabase project ref (the subdomain in your project URL)
SUPABASE_PROJECT_ID=your-project-ref
# Supabase service-role key — Dashboard → Project Settings → API → service_role.
# Server-only. Used to mirror user roles into app_metadata for Realtime RLS.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: full project URL. If omitted it is derived from SUPABASE_PROJECT_ID.
SUPABASE_URL=https://your-project-ref.supabase.co

# Razorpay (Dashboard → Settings → API Keys / Webhooks)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Object storage (MinIO/S3) — optional if using Supabase Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=mdms
S3_REGION=auto

# WhatsApp webhook verify token (Meta Cloud API)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-verify-token
