# ============================================
# MDMS — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================

# ── General ──────────────────────────────────
NODE_ENV=development
APP_NAME="MDMS"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql://mdms:mdms_dev_password@localhost:5432/mdms_dev?schema=public

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ───────────────────────
# Generate with: openssl genrsa 2048
JWT_ACCESS_SECRET=your-access-secret-key-change-me
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Google OAuth 2.0 ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp Business (Meta Cloud API) ───────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v18.0

# ── Object Storage (S3 / Cloudflare R2 / MinIO) ─
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mdms_access_key
S3_SECRET_KEY=mdms_secret_key
S3_BUCKET_NAME=mdms
S3_REGION=auto

# ── Email (SMTP / AWS SES) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MP Production <noreply@mpproduction.com>"

# ── Search Engine (Meilisearch) ──────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# ── Video Streaming (Cloudflare Stream) ──────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# ── Monitoring ───────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Analytics ────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=

# ── Next.js Public Vars ─────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# API is served under the /api/v1 global prefix (see apps/api/src/main.ts)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=
